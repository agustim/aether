# Variables d'entorn per al LLM d'Aether Code
# Copia aquest fitxer a .env i omple els valors reals:
#   cp env.example .env

# URL base de l'API del model de llenguatge (format OpenAI-compatible)
# Exemples:
#   - OpenAI:          https://api.openai.com/v1
#   - Anthropic:       https://api.anthropic.com/v1
#   - Ollama local:    http://localhost:11434/v1
#   - vLLM local:      http://localhost:8000/v1
AETHER_LLM_URL=https://api.openai.com/v1

# Clau d'autenticació (Bearer Token)
# Obtinguda del proveedor del model (OpenAI dashboard, etc.)
AETHER_LLM_KEY=sk-your-api-key-here

# Nom del model a utilitzar
# Exemples: gpt-4o, gpt-4-turbo, claude-3-sonnet, qwen-2.5-coder, etc.
AETHER_LLM_MODEL=gpt-4

# Opcional: activa el mode mock (false = LLM real, true = respostes simulades)
# útil per desenvolupament sense consumir credits
AI_USE_MOCK=true

# ============================================================================
# Telegram Bot (Pas 10)
# ============================================================================

# Token del bot de Telegram (obtingut de @BotFather)
# Exemple: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# IDs de Telegram autoritzats (separats per comes, espais o |)
# Només aquests usuaris poden interactuar amb el bot
# Exemple: 987654321,111222333,444555666
# Per metre-ho en producció, omple aquesta llista!
TELEGRAM_AUTHORIZED_IDS=
